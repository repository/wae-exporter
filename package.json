{
  "name": "wae-exporter",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "fmt": "oxfmt . --write -c oxfmt.config.mts",
    "fmt:check": "oxfmt . --check -c oxfmt.config.mts",
    "lint": "oxlint . --fix -c oxlint.config.mts",
    "lint:check": "oxlint . -c oxlint.config.mts",
    "fix": "pnpm run fmt && pnpm run lint",
    "check": "pnpm run fmt:check && pnpm run lint:check",
    "start": "wrangler dev",
    "test": "vitest",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2",
    "vitest": "~4.1.2",
    "wrangler": "^4.80.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
